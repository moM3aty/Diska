@{
    ViewData["Title"] = "سياسة الاستخدام";
    Layout = "_Layout"; // تأكد من تفعيل الـ Layout الخاص بك
}

<style>
    /* =========================================
           PREMIUM TERMS & CONDITIONS STYLES
           ========================================= */
    :root {
        --tc-bg-body: #f8fafc;
        --tc-card-bg: #ffffff;
        --tc-text-main: #0f172a;
        --tc-text-muted: #64748b;
        --tc-border: #e2e8f0;
        --tc-primary: #4f46e5;
        --tc-accent: #facc15;
        --tc-danger: #ef4444;
        --tc-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.05);
    }

    [data-bs-theme="dark"] {
        --tc-bg-body: #020617;
        --tc-card-bg: #1e293b;
        --tc-text-main: #f8fafc;
        --tc-text-muted: #94a3b8;
        --tc-border: rgba(255, 255, 255, 0.08);
        --tc-primary: #818cf8;
        --tc-accent: #facc15;
        --tc-danger: #f87171;
        --tc-shadow: 0 10px 40px -5px rgba(0, 0, 0, 0.4);
    }

    body {
        background-color: var(--tc-bg-body);
        transition: background-color 0.3s ease, color 0.3s ease;
        font-family: 'Cairo', sans-serif;
    }

    .terms-page-wrapper {
        padding: 60px 0;
        min-height: 85vh;
    }

    .terms-header {
        text-align: center;
        margin-bottom: 50px;
    }

        .terms-header h1 {
            font-size: 2.5rem;
            font-weight: 900;
            color: var(--tc-primary);
            margin-bottom: 15px;
        }

        .terms-header p {
            color: var(--tc-text-muted);
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto;
        }

    .term-card {
        background: var(--tc-card-bg);
        border: 1px solid var(--tc-border);
        border-radius: 20px;
        padding: 35px;
        margin-bottom: 30px;
        box-shadow: var(--tc-shadow);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .term-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.1);
            border-color: rgba(79, 70, 229, 0.3);
        }

    [data-bs-theme="dark"] .term-card:hover {
        box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.6);
    }

    .term-title {
        display: flex;
        align-items: center;
        gap: 15px;
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--tc-text-main);
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 2px dashed var(--tc-border);
    }

        .term-title .icon-box {
            width: 45px;
            height: 45px;
            background: rgba(79, 70, 229, 0.1);
            color: var(--tc-primary);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

    .term-content {
        color: var(--tc-text-muted);
        font-size: 1.05rem;
        line-height: 1.8;
    }

        .term-content strong {
            color: var(--tc-text-main);
            font-weight: 700;
        }

        .term-content ul {
            list-style: none;
            padding: 0;
            margin: 15px 0 0 0;
        }

            .term-content ul li {
                position: relative;
                padding-right: 25px; /* RTL padding */
                margin-bottom: 12px;
            }

                .term-content ul li::before {
                    content: '\f058'; /* FontAwesome check-circle */
                    font-family: 'Font Awesome 5 Free';
                    font-weight: 900;
                    position: absolute;
                    right: 0;
                    top: 2px;
                    color: var(--tc-primary);
                    font-size: 1rem;
                }

    /* مادة إخلاء المسؤولية تأخذ لون تحذيري خفيف */
    .disclaimer-card {
        border: 1px solid rgba(239, 68, 68, 0.3);
        background: linear-gradient(to bottom, var(--tc-card-bg), rgba(239, 68, 68, 0.02));
    }

        .disclaimer-card .icon-box {
            background: rgba(239, 68, 68, 0.1);
            color: var(--tc-danger);
        }

    /* Animation */
    .fade-up {
        animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @@keyframes fadeUp {
        from

    {
        opacity: 0;
        transform: translateY(30px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    @@media (max-width: 768px) {
        .term-card

    {
        padding: 25px;
    }

    .terms-header h1 {
        font-size: 2rem;
    }

    }
</style>

<div class="terms-page-wrapper" dir="rtl">
    <div class="container">

        <div class="terms-header fade-up">
            <h1>سياسة الاستخدام والشروط</h1>
            <p>باستخدامك لمنصة DISKA، فأنت توافق التزامك الكامل بالبنود والشروط الموضحة أدناه. يرجى قراءتها بعناية.</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-9">

                <div class="term-card fade-up" style="animation-delay: 0.1s;">
                    <div class="term-title">
                        <div class="icon-box"><i class="fas fa-book-open"></i></div>
                        المادة الأولى: التعريفات والصفة القانونية
                    </div>
                    <div class="term-content">
                        <p><strong>منصة DISKA:</strong> هي منصة إلكترونية تقنية وسيطة متخصصة حصراً في قطاع الأغذية والمشروبات والمنتجات الاستهلاكية، ومقرها الرئيسي محافظة الدقهلية، جمهورية مصر العربية.</p>
                        <p><strong>طبيعة الخدمة:</strong> يقتصر دور المنصة على توفير "مساحة تقنية" للمستخدمين لعرض منتجاتهم. المنصة ليست طرفاً في أي عملية بيع أو شراء، ولا تضمن جودة المنتجات، ولا تتقاضى عمولات، ولا تمثل أي من الطرفين.</p>
                    </div>
                </div>

                <div class="term-card disclaimer-card fade-up" style="animation-delay: 0.2s;">
                    <div class="term-title">
                        <div class="icon-box"><i class="fas fa-shield-alt"></i></div>
                        المادة الثانية: إخلاء المسؤولية التام (بند عدم التدخل)
                    </div>
                    <div class="term-content">
                        <p><strong>النزاعات بين المستخدمين:</strong> يقر المستخدم بأن منصة DISKA وإدارتها غير مسؤولة قانوناً أو مدنياً أو جنائياً عن أي خلافات أو حالات غش أو أضرار صحية ناتجة عن التعامل بين البائع والمشتري.</p>
                        <p><strong>الجهات الأمنية والرقابية:</strong> المنصة ليست طرفاً في أي بلاغات تُقدم لمباحث الإنترنت أو جهاز حماية المستهلك أو غيرها. يقر المستخدم بأن مسؤوليته تجاه هذه الجهات هي مسؤولية شخصية مباشرة، ولا تلتزم المنصة بتقديم أي بيانات أو تقارير فنية لأي طرف إلا بموجب أمر قضائي ملزم وموجه رسمياً للإدارة.</p>
                        <p><strong>سلامة المنتجات:</strong> تقع المسؤولية الكاملة عن تاريخ الصلاحية، شروط التخزين، وتراخيص تداول الأغذية على عاتق "المعلن" وحده.</p>
                    </div>
                </div>

                <div class="term-card fade-up" style="animation-delay: 0.3s;">
                    <div class="term-title">
                        <div class="icon-box"><i class="fas fa-box-open"></i></div>
                        المادة الثالثة: شروط المحتوى (الأغذية فقط)
                    </div>
                    <div class="term-content">
                        <p><strong>التخصص الحصري:</strong> يُحظر تماماً الإعلان عن العقارات، السيارات، المقاولات، الخدمات الهندسية، أو أي نشاط خارج نطاق الأغذية. سيتم حذف أي محتوى مخالف فوراً.</p>
                        <p><strong>السلع الممنوعة:</strong> يمنع الإعلان عن (الخمور - التبغ والسجائر - الأدوية والمكملات الطبية - المنتجات مجهولة المصدر).</p>
                        <p><strong>الصور والمعلومات:</strong> يجب أن تكون الصور حقيقية للمنتج الغذائي المعروض، وأن تكون المعلومات دقيقة وغير مضللة للمستهلك.</p>
                    </div>
                </div>

                <div class="term-card fade-up" style="animation-delay: 0.4s;">
                    <div class="term-title">
                        <div class="icon-box"><i class="fas fa-user-shield"></i></div>
                        المادة الرابعة: الحظر والرقابة الفنية
                    </div>
                    <div class="term-content">
                        <p>للمنصة الحق المطلق وبإرادتها المنفردة في حذف أي إعلان أو حظر أي حساب (Block) يتبين مخالفته لهذه السياسات أو يسيء استخدام المنصة، دون أدنى مسؤولية ودون الحاجة لإخطار المستخدم أو توضيح الأسباب.</p>
                        <p>يوافق المستخدم على ظهور نظام التقييمات للعامة، وتعتبر التقييمات تعبيراً عن رأي أصحابها ولا تتحمل المنصة أي مسؤولية عن محتواها.</p>
                    </div>
                </div>

                <div class="term-card fade-up" style="animation-delay: 0.5s;">
                    <div class="term-title">
                        <div class="icon-box"><i class="fas fa-check-double"></i></div>
                        المادة الخامسة: نصائح أمان التعامل
                    </div>
                    <div class="term-content">
                        <p>لضمان سلامة التعامل، ننصح المستخدمين بالآتي:</p>
                        <ul>
                            <li>إجراء المقابلات وعمليات الاستلام في أماكن عامة ومفتوحة.</li>
                            <li>فحص المنتج الغذائي والتأكد من تاريخ الإنتاج والصلاحية قبل الدفع.</li>
                            <li>استخدام خاصية "الحظر" (Block) داخل التطبيق في حال التعرض لأي إزعاج من مستخدم آخر.</li>
                        </ul>
                    </div>
                </div>

                <div class="term-card fade-up" style="animation-delay: 0.6s;">
                    <div class="term-title">
                        <div class="icon-box"><i class="fas fa-gavel"></i></div>
                        المادة السادسة: القانون السائد
                    </div>
                    <div class="term-content">
                        <p>تخضع هذه الاتفاقية للقوانين المعمول بها في <strong>جمهورية مصر العربية</strong>، وفي حال نشوب أي نزاع حول تفسير هذه البنود، تكون المحاكم المختصة في <strong>محافظة الدقهلية</strong> هي صاحبة الاختصاص الحصري.</p>
                        <hr class="my-4" style="border-color: var(--tc-border);">
                        <p class="mb-0 text-center fw-bold" style="color: var(--tc-primary);">
                            باستخدامك لمنصة DISKA، فأنت تقر بموافقتك الكاملة على هذه البنود، وتتعهد بعدم ملاحقة المنصة أو إدارتها قضائياً أو جنائياً عن أي تصرف ينتج عن مستخدمين آخرين.
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>